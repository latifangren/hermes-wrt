#!/bin/sh /etc/rc.common
# ====================================================================
# Hermes-WRT Telegram Bot Service Init Script (hbot)
# ====================================================================

START=99
USE_PROCD=1

start_service() {
    # Check if configurations are present
    local token=$(uci -q get hermes.telegram.bot_token)
    local chat_id=$(uci -q get hermes.telegram.chat_id)
    local enabled=$(uci -q get hermes.telegram.enabled || echo "0")

    if [ "$enabled" != "1" ]; then
        echo "Hermes Telegram Bot disabled in configuration."
        return 1
    fi

    if [ -z "$token" ] || [ -z "$chat_id" ]; then
        echo "Hermes Telegram Bot: token or chat_id not configured."
        return 1
    fi

    procd_open_instance
    procd_set_param command /bin/bash /usr/bin/hbot
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "hermes"
}
